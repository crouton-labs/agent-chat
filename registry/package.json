{
  "name": "agent-chat-registry",
  "private": true,
  "type": "module",
  "description": "Dev/build harness for the @crouton-kit/agent-chat shadcn registry item. The harness itself never ships — it exists to typecheck/build/preview registry/src/components/agent-chat/* against real shadcn primitives + @crouton-kit/agent-chat-core.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "registry:build": "shadcn build"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@crouton-kit/agent-chat-core": "workspace:*",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "streamdown": "latest",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "shadcn": "4.13.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.1.3"
  }
}
